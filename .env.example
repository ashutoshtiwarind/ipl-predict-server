# ─── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Paste your Atlas connection string here after creating the cluster
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://ashutoshtiwarind:@cluster0.drkxv2p.mongodb.net/ipl-predictor?retryWrites=true&w=majority
# mongodb+srv://ashutoshtiwarind:ONEpiece7@cluster0.drkxv2p.mongodb.net/ipl-predictor?retryWrites=true&w=majority
# ─── JWT ────────────────────────────────────────────────────────────────────────
# Change this to a long random secret in production
JWT_SECRET=ipl_predictor_super_secret_change_me_in_prod
JWT_EXPIRES_IN=7d

# ─── Server ─────────────────────────────────────────────────────────────────────
PORT=5001
CLIENT_URL=http://localhost:5173
NODE_ENV=development
